# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/erp_admin

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Admin Seed ───────────────────────────────────────────
SEED_ADMIN_USERNAME=vicks
SEED_ADMIN_EMAIL=admin@university.edu
SEED_ADMIN_PASSWORD=vicks@123
SEED_ADMIN_NAME=Super Admin

# ─── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Gmail sender (use an App Password, not your normal Gmail password)
EMAIL_USER=accounts@example.com
EMAIL_PASS=your_gmail_app_password
